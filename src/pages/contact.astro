---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="聯絡 林彥翔 Lin Yan-Xiang">
  <div class="container">
    <div style="padding: 3rem 0;">
      <p class="label">聯絡 / Contact</p>

      <div class="bilingual" style="margin-bottom: 2.4rem;">
        <div class="zh" style="font-size:0.9rem; line-height:1.9;">
          <p>歡迎來信洽詢合作、展覽或其他事宜。</p>
        </div>
        <div class="en" style="font-size:0.84rem; line-height:1.9; color:#666;">
          <p>Feel free to reach out for collaborations, exhibitions, or any enquiries.</p>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:1.2rem;">
        <div>
          <div class="label" style="margin-bottom:0.4rem;">Email</div>
          <a href="mailto:your@email.com" style="font-size:0.92rem;">your@email.com</a>
        </div>
        <div>
          <div class="label" style="margin-bottom:0.4rem;">Instagram</div>
          <a href="https://www.instagram.com/" target="_blank" rel="noopener" style="font-size:0.92rem;">
            @yourhandle
          </a>
        </div>
        <div>
          <div class="label" style="margin-bottom:0.4rem;">Based in</div>
          <span style="font-size:0.92rem; color:#555;">台北 Taipei, Taiwan</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="林彥翔 Lin Yan-Xiang" description="藝術家 林彥翔 個人網站">
  <div class="container">
    <div class="hero">
      <div class="hero-text">
        <h1 class="artist-name">
          林彥翔
          <span>Lin, Yan-Xiang</span>
        </h1>
        <p class="bio">
          出生於臺灣桃園，畢業於北藝大藝術跨域研究所。<br />
          創作類型主要擴及影像、行動及書寫，關注生態環境、地緣政治、宗教信仰等議題，以及人如何回應自身所面臨之生命政治。以影像為創作核心，提出且實踐「行動電影」之概念，將影像作為藝術行動的一種可視化作為。
        </p>
        <p class="bio-en">
          Born in Taoyuan, Taiwan. Graduated from the Institute of Trans-disciplinary Arts, TNUA.<br />
          Working across video, action, and writing — with research centred on ecology, geopolitics,
          and religion — he proposes <em>Art Activism Cinema</em> as a methodology for artistic intervention.
        </p>
      </div>
      <div class="hero-photo">
        <img src="/images/profile.jpg" alt="林彥翔 Lin Yan-Xiang" width="160" height="160" />
      </div>
    </div>

    <!-- Current / upcoming -->
    <section>
      <p class="label">展出資訊 / Exhibition Info</p>
      <div class="entry">
        <span class="entry-year">2026</span>
        <div>
          <div class="entry-title">《仙人‧跳—土地公的藝術家朋友們》 <span class="tag">即將展出</span></div>
          <div class="entry-meta">桃園市土地公文化館</div>
        </div>
      </div>
      <div class="entry">
        <span class="entry-year">2026</span>
        <div>
          <div class="entry-title">《臺南新藝獎 倒風內山：文明發酵術》 <span class="tag">即將展出</span></div>
          <div class="entry-meta">醉美空間，臺南</div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
.hero {
  padding: 4rem 0 2.4rem;
  display: flex;
  gap: 3rem;
  align-items: flex-start;
}
.hero-text { flex: 1; }
.artist-name {
  font-size: 1.35rem;
  font-weight: 400;
  letter-spacing: 0.04em;
  margin-bottom: 1.6rem;
  line-height: 1.3;
}
.artist-name span {
  display: block;
  font-size: 0.9rem;
  letter-spacing: 0.18em;
  color: #999;
  margin-top: 0.3rem;
  text-transform: uppercase;
}
.bio    { font-size: 0.9rem;  line-height: 1.9; margin-bottom: 1rem; }
.bio-en { font-size: 0.84rem; line-height: 1.9; color: #666; }
.hero-photo { flex-shrink: 0; }
.hero-photo img { width: 160px; height: 160px; object-fit: cover; }
@media (max-width: 560px) {
  .hero { flex-direction: column-reverse; gap: 1.4rem; }
  .hero-photo img { width: 120px; height: 120px; }
}
</style>

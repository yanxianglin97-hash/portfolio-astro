---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV" description="林彥翔 Lin Yan-Xiang — 藝術家簡歷">
  <div class="container">
    <div style="padding: 3rem 0 0;">
      <h2 style="font-size:1.2rem; font-weight:400; margin-bottom:2rem;">
        林彥翔
        <span style="font-size:0.85rem; letter-spacing:0.14em; color:#999; margin-left:0.8rem; text-transform:uppercase;">
          Lin, Yan-Xiang
        </span>
      </h2>

      <!-- Bio bilingual -->
      <div class="bilingual" style="margin-bottom:1rem;">
        <p class="zh" style="font-size:0.9rem; line-height:1.9;">
          1997 年生於桃園。畢業於國立臺北藝術大學跨域藝術研究所。
          創作涉及影像、行動及書寫，以生態、地緣政治與宗教信仰為研究核心，
          透過田野調查與藝術介入提出問題，並以「行動電影」作為其實踐的方法論。
        </p>
        <p class="en" style="font-size:0.84rem; line-height:1.9; color:#666;">
          Born in 1997 in Taoyuan, Taiwan. Graduated from the Graduate Institute of
          Trans-disciplinary Arts, Taipei National University of the Arts (TNUA).
          Working across video, action, and writing — with research centred on ecology,
          geopolitics, and religion — he proposes <em>activist cinema</em> as a methodology
          for artistic intervention.
        </p>
      </div>
    </div>

    <!-- Education -->
    <section>
      <p class="label">學歷 / Education</p>
      <div class="entry">
        <span class="entry-year">2024</span>
        <div>
          <div class="entry-title">國立臺北藝術大學 跨域藝術研究所</div>
          <div class="entry-meta-en">Graduate Institute of Trans-disciplinary Arts, TNUA — MFA</div>
        </div>
      </div>
      <div class="entry">
        <span class="entry-year">2020</span>
        <div>
          <div class="entry-title">國立臺灣藝術大學 雕塑學系</div>
          <div class="entry-meta-en">Department of Sculpture, NTUA — BFA</div>
        </div>
      </div>
    </section>

    <!-- Solo Exhibitions -->
    <section>
      <p class="label">個展 / Solo Exhibitions</p>
      <div class="entry">
        <span class="entry-year">2024</span>
        <div>
          <div class="entry-title">山若有神</div>
          <div class="entry-meta-en">If the Mountain Has a Spirit</div>
          <div class="entry-meta">展覽地點</div>
        </div>
      </div>
      <div class="entry">
        <span class="entry-year">2023</span>
        <div>
          <div class="entry-title">空城現場</div>
          <div class="entry-meta-en">Ghost City / Aerotropolis</div>
          <div class="entry-meta">展覽地點</div>
        </div>
      </div>
    </section>

    <!-- Group Exhibitions -->
    <section>
      <p class="label">聯展 / Group Exhibitions</p>
      <div class="entry">
        <span class="entry-year">2025</span>
        <div>
          <div class="entry-title">寶藏巖夏日藝術展</div>
          <div class="entry-meta-en">Treasure Hill Summer Art Exhibition</div>
          <div class="entry-meta">寶藏巖國際藝術村 ／ 2025.06.20 — 08.16</div>
        </div>
      </div>
      <div class="entry">
        <span class="entry-year">2024</span>
        <div>
          <div class="entry-title">臺北美術獎</div>
          <div class="entry-meta-en">Taipei Art Awards</div>
          <div class="entry-meta">臺北市立美術館</div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section>
      <p class="label">獲獎 / Awards</p>
      <div class="entry">
        <span class="entry-year">2024</span>
        <div>
          <div class="entry-title">臺北美術獎 優選 <span class="tag">優選</span></div>
          <div class="entry-meta-en">Honorable Mention, Taipei Art Awards</div>
          <div class="entry-meta">臺北市立美術館</div>
        </div>
      </div>
      <div class="entry">
        <span class="entry-year">2022</span>
        <div>
          <div class="entry-title">北藝大當代藝術獎 首獎 <span class="tag">首獎</span></div>
          <div class="entry-meta-en">Grand Prize, TNUA Contemporary Art Prize</div>
          <div class="entry-meta">國立臺北藝術大學</div>
        </div>
      </div>
    </section>

    <!-- Contact (inline in CV) -->
    <section>
      <p class="label">聯絡 / Contact</p>
      <div class="entry">
        <span class="entry-year"></span>
        <div>
          <div class="entry-title">
            <a href="mailto:your@email.com">your@email.com</a>
          </div>
          <div class="entry-meta">
            <a href="https://www.instagram.com/" target="_blank" rel="noopener">Instagram</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

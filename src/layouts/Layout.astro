---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '林彥翔 Lin Yan-Xiang', description = 'Artist portfolio' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/cv`,       labelEn: 'CV' },
  { href: `${base}/projects`, labelEn: 'Projects' },
  { href: `${base}/contact`,  labelEn: 'Contact' },
];
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === '林彥翔 Lin Yan-Xiang' ? title : `${title} — 林彥翔`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="site-logo">林彥翔 LIN YAN-XIANG</a>
        <nav class="site-nav">
          {navLinks.map(link => (
            <a
              href={link.href}
              aria-current={currentPath.startsWith(link.href.replace(base, '')) ? 'page' : undefined}
            >
              {link.labelEn}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        © {new Date().getFullYear()} 林彥翔 Lin Yan-Xiang
      </div>
    </footer>
  </body>
</html>
